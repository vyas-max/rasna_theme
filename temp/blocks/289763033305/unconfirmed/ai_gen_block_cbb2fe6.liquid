{% doc %}
  @prompt
    i want to add an section for banner and if i add more than 1 image it turns to slideshow where i can upload my image, for both desktop and mobile, and can adjust margin and padding also the radius
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign slides_count = 0
  for i in (1..5)
    assign desktop_image_key = 'desktop_image_' | append: i
    assign mobile_image_key = 'mobile_image_' | append: i
    assign desktop_image = block.settings[desktop_image_key]
    assign mobile_image = block.settings[mobile_image_key]
    if desktop_image != blank or mobile_image != blank
      assign slides_count = slides_count | plus: 1
    endif
  endfor
%}

{% style %}
  .ai-banner-slideshow-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-banner-slideshow__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
  }

  .ai-banner-slideshow__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
  }

  .ai-banner-slideshow__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    pointer-events: none;
  }

  .ai-banner-slideshow__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-banner-slideshow__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-banner-slideshow__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-slideshow__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-slideshow__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-banner-slideshow__mobile-image-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-slideshow__desktop-image-{{ ai_gen_id }} {
      display: none;
    }

    .ai-banner-slideshow__mobile-image-{{ ai_gen_id }} {
      display: block;
    }
  }

  .ai-banner-slideshow__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .ai-banner-slideshow__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-banner-slideshow__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-banner-slideshow__arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease;
  }

  .ai-banner-slideshow__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
  }

  .ai-banner-slideshow__arrow-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-banner-slideshow__arrow-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-banner-slideshow__arrow-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  {% if slides_count <= 1 %}
    .ai-banner-slideshow__controls-{{ ai_gen_id }},
    .ai-banner-slideshow__arrow-{{ ai_gen_id }} {
      display: none;
    }
  {% endif %}
{% endstyle %}

<banner-slideshow-{{ ai_gen_id }} class="ai-banner-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-slideshow__container-{{ ai_gen_id }}">
    <div class="ai-banner-slideshow__slides-{{ ai_gen_id }}">
      {% liquid
        assign has_any_image = false
        for i in (1..5)
          assign desktop_image_key = 'desktop_image_' | append: i
          assign mobile_image_key = 'mobile_image_' | append: i
          assign desktop_image = block.settings[desktop_image_key]
          assign mobile_image = block.settings[mobile_image_key]
          if desktop_image != blank or mobile_image != blank
            assign has_any_image = true
          endif
        endfor
      %}

      {% if has_any_image %}
        {% for i in (1..5) %}
          {% liquid
            assign desktop_image_key = 'desktop_image_' | append: i
            assign mobile_image_key = 'mobile_image_' | append: i
            assign desktop_image = block.settings[desktop_image_key]
            assign mobile_image = block.settings[mobile_image_key]
          %}

          {% if desktop_image != blank or mobile_image != blank %}
            <div class="ai-banner-slideshow__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}">
              {% if desktop_image != blank %}
                <img
                  src="{{ desktop_image | image_url: width: 2000 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  loading="lazy"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                  class="ai-banner-slideshow__image-{{ ai_gen_id }} ai-banner-slideshow__desktop-image-{{ ai_gen_id }}"
                >
              {% endif %}

              {% if mobile_image != blank %}
                <img
                  src="{{ mobile_image | image_url: width: 1000 }}"
                  alt="{{ mobile_image.alt | escape }}"
                  loading="lazy"
                  width="{{ mobile_image.width }}"
                  height="{{ mobile_image.height }}"
                  class="ai-banner-slideshow__image-{{ ai_gen_id }} ai-banner-slideshow__mobile-image-{{ ai_gen_id }}"
                >
              {% elsif desktop_image != blank %}
                <img
                  src="{{ desktop_image | image_url: width: 1000 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  loading="lazy"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                  class="ai-banner-slideshow__image-{{ ai_gen_id }} ai-banner-slideshow__mobile-image-{{ ai_gen_id }}"
                >
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-banner-slideshow__slide-{{ ai_gen_id }} active">
          <div class="ai-banner-slideshow__placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-banner-slideshow__empty-state-{{ ai_gen_id }}">
              Add images to create your banner
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if slides_count > 1 %}
      <button
        class="ai-banner-slideshow__arrow-{{ ai_gen_id }} ai-banner-slideshow__arrow-{{ ai_gen_id }}--prev"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-banner-slideshow__arrow-{{ ai_gen_id }} ai-banner-slideshow__arrow-{{ ai_gen_id }}--next"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <div class="ai-banner-slideshow__controls-{{ ai_gen_id }}">
        {% for i in (1..slides_count) %}
          <button
            class="ai-banner-slideshow__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            aria-label="Go to slide {{ forloop.index }}"
            data-slide-index="{{ forloop.index0 }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</banner-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-banner-slideshow__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-banner-slideshow__dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-banner-slideshow__arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-banner-slideshow__arrow-{{ ai_gen_id }}--next');

        if (this.slides.length <= 1) return;

        this.setupEventListeners();
        this.startAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.goToSlide(this.currentSlide - 1);
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.goToSlide(this.currentSlide + 1);
            this.resetAutoplay();
          });
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.slideIndex);
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });
      }

      goToSlide(index) {
        if (index < 0) {
          index = this.slides.length - 1;
        } else if (index >= this.slides.length) {
          index = 0;
        }

        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }
      }

      startAutoplay() {
        const autoplayEnabled = {{ block.settings.autoplay }};
        const autoplaySpeed = {{ block.settings.autoplay_speed }} * 1000;

        if (autoplayEnabled && this.slides.length > 1) {
          this.autoplayInterval = setInterval(() => {
            this.goToSlide(this.currentSlide + 1);
          }, autoplaySpeed);
        }
      }

      resetAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('banner-slideshow-{{ ai_gen_id }}', BannerSlideshow{{ ai_gen_id }});
  })();
</script>

